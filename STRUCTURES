PROGRAM ON STRUCTURES:

#include <stdio.h>


struct student {

char name[50];

int rollnumber;

float marks;

};


int main() {

struct student S[3];

int i;


for(i = 0; i < 3; i++) {

printf("Enter the name of the student: ");

scanf("%s", S[i].name);


printf("Enter the roll number: ");

scanf("%d", &S[i].rollnumber);


printf("Enter the marks: ");

scanf("%f", &S[i].marks);

}


printf("\n--- Student Details ---\n");


for(i = 0; i < 3; i++) {

printf("Name of the student is %s\n", S[i].name);

printf("Roll number is %d\n", S[i].rollnumber);

printf("Marks obtained is %.2f\n", S[i].marks);

}


return 0;

}

