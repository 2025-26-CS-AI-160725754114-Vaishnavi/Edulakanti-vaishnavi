#include <stdio.h>

#include <stdlib.h>


struct Node

{

int data;

struct Node *next;

struct Node *prev;

};


struct Node *head = NULL, *temp, *current;

void insertBegin(int x)

{

temp = (struct Node*)malloc(sizeof(struct Node));

temp->data = x;

temp->prev = NULL;

temp->next = head;


if(head != NULL)

head->prev = temp;


head = temp;

}


void insertEnd(int x)

{

temp = (struct Node*)malloc(sizeof(struct Node));

temp->data = x;

temp->next = NULL;


if(head == NULL)

{

temp->prev = NULL;

head = temp;

return;

}


current = head;


while(current->next != NULL)

current = current->next;


current->next = temp;

temp->prev = current;

}

void insertPosition(int x, int pos)

{

if(pos == 1)

{

insertBegin(x);

return;

}


temp = (struct Node*)malloc(sizeof(struct Node));

temp->data = x;


current = head;

int i = 1;


while(i < pos-1 && current != NULL)

{

current = current->next;

i++;

}


if(current == NULL)

{

printf("Position out of range\n");

free(temp);

return;

}

temp->next = current->next;

temp->prev = current;

if(current->next != NULL)

current->next->prev = temp;

current->next = temp;

}

void deleteBegin()

{

if(head == NULL)

{

printf("Nothing to delete\n");

return;

}

temp = head;

head = head->next;

if(head != NULL)

head->prev = NULL;

free(temp);

}

void deleteEnd()

{

if(head == NULL)

{

printf("Nothing to delete\n");

return;

}


if(head->next == NULL)

{

free(head);

head = NULL;

return;

}


current = head;


while(current->next != NULL)

current = current->next;


current->prev->next = NULL;

free(current);

}


void deletePosition(int pos)

{

if(head == NULL)

{

printf("Nothing to delete\n");

return;

}


if(pos == 1)

{

deleteBegin();

return;

}


current = head;

int i = 1;


while(i < pos && current != NULL)

{

current = current->next;

i++;

}


if(current == NULL)

{

printf("Position out of range\n");

return;

}


if(current->next != NULL)

current->next->prev = current->prev;


if(current->prev != NULL)

current->prev->next = current->next;


free(current);

}


void display()

{

if(head == NULL)

{

printf("List is empty\n");

return;

}


current = head;

printf("DLL: ");


while(current != NULL)

{

printf("%d <-> ", current->data);

current = current->next;

}


printf("NULL\n");

}


int main()

{

int choice, x, pos;


while(1)

{

printf("\n--- DOUBLY LINKED LIST ---\n");

printf("1. Insert Begin\n");

printf("2. Insert End\n");

printf("3. Insert Position\n");

printf("4. Delete Begin\n");

printf("5. Delete End\n");

printf("6. Delete Position\n");

printf("7. Display\n");

printf("8. Exit\n");


